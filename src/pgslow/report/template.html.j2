<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>pgslow report - {{ db }}</title>
<style>
{{ css|safe }}
</style>
</head>
<body>
<div class="wrap">
  <header class="head">
    <div class="brand">pgslow<span class="v">{{ tool_version }}</span></div>
    <div class="meta">database <b>{{ db }}</b> &middot; PostgreSQL <b>{{ pg_version }}</b> &middot; generated <b>{{ generated_at }}</b></div>
  </header>

  <section class="summary">
    <div class="stat"><span class="label">queries shown</span><span class="value">{{ shown_count }} / {{ total_queries }}</span></div>
    <div class="stat"><span class="label">total db time</span><span class="value">{{ total_db_time }} ms</span></div>
    <div class="stat"><span class="label">top consumer</span><span class="value{{ ' crit' if top_pct_crit else '' }}">{{ top_pct }}%</span></div>
    <div class="stat"><span class="label">ranked by</span><span class="value">{{ order }}</span></div>
  </section>

  <table>
    <thead>
      <tr>
        <th class="num" data-key="rank">#</th>
        <th>query</th>
        <th class="num" data-key="calls">calls</th>
        <th class="num" data-key="total">total ms</th>
        <th class="num" data-key="mean">mean ms</th>
        <th class="num" data-key="pct">% total</th>
        <th class="num" data-key="cache">cache %</th>
        <th>flags</th>
      </tr>
    </thead>
    <tbody>
      {% for q in rows %}
      <tr class="row">
        <td class="rank" data-col="rank" data-value="{{ loop.index }}">{{ loop.index }}</td>
        <td class="query"><span class="caret">&rsaquo;</span>{{ q.short }}</td>
        <td class="num" data-col="calls" data-value="{{ q.calls }}">{{ q.calls_fmt }}</td>
        <td class="num" data-col="total" data-value="{{ q.total }}">{{ q.total_fmt }}</td>
        <td class="num" data-col="mean" data-value="{{ q.mean }}">{{ q.mean_fmt }}</td>
        <td class="num pct" data-col="pct" data-value="{{ q.pct }}"><span class="bar" style="width: {{ q.pct_bar }}%"></span><span class="val{{ ' crit' if q.pct_crit else '' }}">{{ q.pct_fmt }}</span></td>
        <td class="num" data-col="cache" data-value="{{ q.cache_sort }}"><span class="{{ q.cache_class }}">{{ q.cache_fmt }}</span></td>
        <td class="flags">{% for f in q.flags %}<span class="flag {{ f }}">{{ f }}</span>{% endfor %}</td>
      </tr>
      <tr class="detail" hidden>
        <td colspan="8">
          <div class="detail-grid">
            <div class="block">
              <div class="block-label">query</div>
              <pre class="q">{{ q.full }}</pre>
            </div>
            <div class="block">
              <div class="block-label">{{ q.plan_label }}</div>
              <pre class="plan{{ '' if q.has_plan else ' note' }}">{{ q.plan }}</pre>
            </div>
            <div class="detail-meta">queryid {{ q.queryid }}</div>
          </div>
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <footer class="foot">
    Generated by pgslow {{ tool_version }} &middot; read-only analysis of pg_stat_statements &middot; plans shown with EXPLAIN only (queries not executed).
  </footer>
</div>
<script>
{{ js|safe }}
</script>
</body>
</html>
